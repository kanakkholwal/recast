{
  "name": "recast",
  "private": true,
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "turbo": "^2.9.6"
  },
  "scripts": {
    "setup:ffmpeg": "node scripts/setup.mjs",
    "dev": "turbo dev",
    "dev:desktop": "turbo dev --filter=recast-desktop",
    "dev:web": "turbo dev --filter=recast-web",
    "build": "turbo build",
    "check": "turbo check",
    "prepare:assets-wallpapers": "node scripts/prepare-backgrounds.mjs",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "release:prepare": "node scripts/release-prepare.mjs",
    "sync:changelog": "node scripts/sync-desktop-changelog.mjs"
  },
  "packageManager": "pnpm@10.23.0"
}