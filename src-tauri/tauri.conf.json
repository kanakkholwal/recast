{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "trace",
  "version": "0.0.1",
  "identifier": "com.nexonauts.trace",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:4000",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "recording-panel",
        "title": "Trace",
        "width": 380,
        "height": 64,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}