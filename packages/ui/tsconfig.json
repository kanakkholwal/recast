{
	"compilerOptions": {
	"rewriteRelativeImportExtensions": true,
		"allowJs": true,
		"checkJs": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"module": "es2015",
		"moduleResolution": "bundler",
		"lib": ["ES2022"],
        "baseUrl": ".",
        "paths": {
			"$lib": ["src/lib/*"],
			"$hooks": ["src/hooks/*"],
			"$components": ["src/components/*"],
			"$ui": ["src/components/ui/*"],

        }
	},
	"include": ["src",]
}